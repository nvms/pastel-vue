{
  "name": "pastel-vue",
  "version": "0.7.1",
  "description": "A pastel-toned Vue 3 component library for building calm, modern interfaces and AI-focused tooling.",
  "type": "module",
  "license": "MIT",
  "author": "nvms",
  "homepage": "https://nvms.github.io/pastel-vue/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvms/pastel-vue.git"
  },
  "bugs": {
    "url": "https://github.com/nvms/pastel-vue/issues"
  },
  "keywords": [
    "vue",
