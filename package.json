    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.6",
    "@iconify/vue": "^5.0.1",
    "@internationalized/date": "^3.12.1",
    "diff": "^9.0.0",
