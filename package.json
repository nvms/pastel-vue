    "prismjs": "^1.30.0",
    "reka-ui": "^2.9.7"
  },
  "devDependencies": {
    "@histoire/plugin-vue": "^0.17.17",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify/utils": "^3.1.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "histoire": "^0.17.17",
    "vite": "^5.4.0",
    "vue": "^3.5.13"
